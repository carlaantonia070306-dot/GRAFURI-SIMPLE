#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int citire_graf(char numefisier[], int* nr_vrf, int* nr_muchii, int g[100][3])
{
    FILE* f;

    f = fopen(numefisier, "r");
    if (f == NULL)
        return 0;

    fscanf(f, "%d %d", nr_vrf, nr_muchii);

    for (int i = 0; i < *nr_muchii; i++)
        fscanf(f, "%d %d %d", &g[i][0], &g[i][1], &g[i][2]);

    fclose(f);
    return 1;
}

int pondere_muchie(int g[100][3], int nr_muchii, int x, int y)
{
    for (int i = 0; i < nr_muchii; i++)
        if ((g[i][0] == x && g[i][1] == y) ||
            (g[i][0] == y && g[i][1] == x))
            return g[i][2];

    return -1;
}

int este_drum(int g[100][3], int nr_muchii, int secventa[], int k)
{
    for (int i = 0; i < k - 1; i++)
        if (pondere_muchie(g, nr_muchii, secventa[i], secventa[i + 1]) == -1)
            return 0;

    return 1;
}

void subdrum_elementar(int secventa[], int k, int subdrum[], int* lungime)
{
    *lungime = 0;

    for (int i = 0; i < k; i++)
    {
        int poz = -1;

        for (int j = 0; j < *lungime; j++)
            if (subdrum[j] == secventa[i])
                poz = j;

        if (poz == -1)
        {
            subdrum[*lungime] = secventa[i];
            (*lungime)++;
        }
        else
        {
            *lungime = poz + 1;
        }
    }
}

int cost_drum(int g[100][3], int nr_muchii, int drum[], int k)
{
    int cost = 0;
    int p;

    for (int i = 0; i < k - 1; i++)
    {
        p = pondere_muchie(g, nr_muchii, drum[i], drum[i + 1]);

        if (p == -1)
            return -1;

        cost = cost + p;
    }

    return cost;
}

