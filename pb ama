#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int n; //nr vf
int a[101][101]; //mat adiacenta
int viz[101]; //retine ce noduri am vizitat

int C(int i, int j, int Cost) // de unde plec, unde vr sa ajung
{
    int k;

    if (i == j)
        return 1;

    viz[i] = 1;

    for (k = 1; k <= n; k++)
    {
        if (a[i][k] != 0 && viz[k] == 0 && Cost >= a[i][k])
        {
            if (C(k, j, Cost - a[i][k]))
                return 1;
        }
    }

    return 0;
}

int main()
{
    int m, x, y, cost;
    int i, j, Cost;

    printf("Introduceti numarul de varfuri n: ");
    scanf("%d", &n);

    printf("Introduceti numarul de muchii m: ");
    scanf("%d", &m);

    printf("Introduceti muchiile (varf1 varf2 cost):\n");

    for (int p = 1; p <= m; p++)
    {
        scanf("%d %d %d", &x, &y, &cost);

        a[x][y] = cost;
        a[y][x] = cost;   // aici imi genereaza matricea de adiacenta
    }

    printf("Introduceti varful de plecare i: ");
    scanf("%d", &i);

    printf("Introduceti varful destinatie j: ");
    scanf("%d", &j);

    printf("Introduceti costul maxim admis Cost: ");
    scanf("%d", &Cost);

    if (C(i, j, Cost))
        printf("Exista un drum de la %d la %d cu cost maxim %d.\n", i, j, Cost);
    else
        printf("Nu exista un astfel de drum.\n");

    return 0;
}
