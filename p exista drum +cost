#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int citire_graf(char numefisier[], int* nr_vrf, int* nr_muchii, int g[100][3])
{
    FILE* f;

    f = fopen(numefisier, "r");
    if (f == NULL)
        return 0;

    fscanf(f, "%d %d", nr_vrf, nr_muchii);

    for (int i = 0; i < *nr_muchii; i++)
        fscanf(f, "%d %d %d", &g[i][0], &g[i][1], &g[i][2]);

    fclose(f);
    return 1;
}

int pondere_muchie(int g[100][3], int nr_muchii, int x, int y)
{
    for (int i = 0; i < nr_muchii; i++)
        if ((g[i][0] == x && g[i][1] == y) ||
            (g[i][0] == y && g[i][1] == x))
            return g[i][2];

    return -1;
}

int cost_drum(int g[100][3], int nr_muchii, int secventa[], int k)
{
    int cost = 0;
    int p;

    for (int i = 0; i < k - 1; i++)
    {
        p = pondere_muchie(g, nr_muchii, secventa[i], secventa[i + 1]);

        if (p == -1)
            return -1;

        cost = cost + p;
    }

    return cost;
}

int main()
{
    char numefisier[20];
    int n, m, tabel[100][3], er;
    int k, secventa[100];
    int cost;

    printf("Introduceti fisierul din care cititi graful: ");
    scanf("%s", numefisier);

    er = citire_graf(numefisier, &n, &m, tabel);

    if (er == 0)
    {
        printf("Eroare la deschiderea fisierului!\n");
        return 0;
    }

    printf("\nNumarul de varfuri este: %d\n", n);
    printf("Numarul de muchii este: %d\n", m);

    printf("Muchiile sunt:\n");
    for (int i = 0; i < m; i++)
        printf("%d %d Ponderea muchiei este: %d\n",
            tabel[i][0], tabel[i][1], tabel[i][2]);

    printf("\nIntroduceti numarul de varfuri din secventa: ");
    scanf("%d", &k);

    printf("Introduceti secventa de varfuri:\n");
    for (int i = 0; i < k; i++)
        scanf("%d", &secventa[i]);

    cost = cost_drum(tabel, m, secventa, k);

    if (cost != -1)
    {
        printf("Secventa data este drum in graf.\n");
        printf("Costul drumului este: %d\n", cost);
    }
    else
        printf("Secventa data NU este drum in graf.\n");

    return 1;
}
