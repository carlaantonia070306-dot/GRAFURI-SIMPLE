#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

void DF(int v, int a[100][100], int vizitat[100], int n) //v-vf in care ma aflu, a-mat adiacenta, vizitat- vec care tine minte unde am fost, n-nr vf
{
    vizitat[v] = 1; //marchez vf ca vizitat

    printf("%d ", v + 1);

    for (int i = 0; i < n; i++)
        if (a[v][i] == 1 && vizitat[i] == 0) //daca exista muchie si nu am fost inca acolo
            DF(i, a, vizitat, n);
}

int main()
{
    int n, m;
    int a[100][100];
    int vizitat[100];
    int vf1, vf2;
    int v0;

    printf("Numar varfuri: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++)
    {
        vizitat[i] = 0;

        for (int j = 0; j < n; j++)
            a[i][j] = 0;
    }

    printf("Numar muchii: ");
    scanf("%d", &m);

    printf("Introduceti muchiile:\n");

    for (int i = 0; i < m; i++)
    {
        scanf("%d %d", &vf1, &vf2);

        a[vf1 - 1][vf2 - 1] = 1;
        a[vf2 - 1][vf1 - 1] = 1;
    }

    printf("Nod start: ");
    scanf("%d", &v0);

    printf("Parcurgere DF:\n");

    DF(v0 - 1, a, vizitat, n);

    return 0;
}
