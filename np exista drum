#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int citire_graf(char numefisier[], int* nr_vrf, int* nr_muchii, int g[100][2])
{
    FILE* f;

    f = fopen(numefisier, "r");
    if (f == NULL)
        return 1;

    fscanf(f, "%d %d", nr_vrf, nr_muchii);

    for (int i = 0; i < *nr_muchii; i++)
        fscanf(f, "%d %d", &g[i][0], &g[i][1]);

    fclose(f);

    return 0;
}

int exista_muchie(int g[100][2], int nr_muchii, int x, int y)
{
    for (int i = 0; i < nr_muchii; i++)
        if ((g[i][0] == x && g[i][1] == y) ||
            (g[i][0] == y && g[i][1] == x))
            return 1;

    return 0;
}

int este_drum(int g[100][2], int nr_muchii, int secventa[], int k)
{
    for (int i = 0; i < k - 1; i++)
        if (exista_muchie(g, nr_muchii, secventa[i], secventa[i + 1]) == 0)
            return 0;

    return 1;
}

int main()
{
    char numefisier[20];
    int n, m, tabel[100][2], er;
    int k, secventa[100];

    printf("Introduceti fisierul din care cititi graful: ");
    scanf("%s", numefisier);

    er = citire_graf(numefisier, &n, &m, tabel);

    if (er == 1)
    {
        printf("Eroare la deschiderea fisierului!\n");
        return 0;
    }

    printf("Numarul de varfuri este: %d\n", n);
    printf("Numarul de muchii este: %d\n", m);

    printf("Muchiile sunt:\n");
    for (int i = 0; i < m; i++)
        printf("%d %d\n", tabel[i][0], tabel[i][1]);

    printf("\nIntroduceti numarul de varfuri din secventa: ");
    scanf("%d", &k);

    printf("Introduceti secventa de varfuri:\n");
    for (int i = 0; i < k; i++)
        scanf("%d", &secventa[i]);

    if (este_drum(tabel, m, secventa, k) == 1)
        printf("Secventa data este drum in graf.\n");
    else
        printf("Secventa data NU este drum in graf.\n");

    return 0;
}
